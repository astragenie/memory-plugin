#!/usr/bin/env bun
// astramem — AstraMemory CLI dispatcher (Wave 2 Track C)
// Subcommands: ingest-transcript | recall | remember | health | config | doctor | connect
// Global: --provider local|saas|auto  (parsed, stored, passed to subcommands)
//         --help | -h                  (prints usage)
//         --version                    (prints 0.5.2)

const VERSION = '0.5.2';

const SUBCOMMANDS = ['ingest-transcript', 'recall', 'remember', 'health', 'config', 'doctor', 'connect'] as const;
type Subcommand = typeof SUBCOMMANDS[number];
type Provider = 'local' | 'saas' | 'auto';

const HELP = `
astramem — AstraMemory CLI v${VERSION}

Usage: astramem [--provider local|saas|auto] <subcommand> [options]

Subcommands:
  ingest-transcript   Ingest a JSONL transcript file (fire-and-forget; hook shim target)
  recall              Recall memories matching a query
  remember            Store a new memory item
  health              Probe the selected provider's /health endpoint
  config              Get or set configuration (config get [key] | config set <key> <val>)
  doctor              Diagnose selector resolution, logs, env vars, and config
  connect             Connect to the local AstraMemory daemon

Global flags:
  --provider local|saas|auto  Override provider selection
  --help, -h                  Show this help message
  --version, -v               Show version

Run 'astramem <subcommand> --help' for subcommand-specific usage.
`.trimStart();

function parseGlobals(argv: string[]): { provider: Provider | null; remaining: string[] } {
  const remaining: string[] = [];
  let provider: Provider | null = null;

  for (let i = 0; i < argv.length; i++) {
    if (argv[i] === '--provider' && i + 1 < argv.length) {
      const val = argv[++i]!;
      if (val === 'local' || val === 'saas' || val === 'auto') {
        provider = val;
      } else {
        process.stderr.write(`astramem: unknown provider '${val}'. Use local|saas|auto.\n`);
        process.exit(1);
      }
    } else {
      remaining.push(argv[i]!);
    }
  }
  return { provider, remaining };
}

async function main(): Promise<void> {
  const args = process.argv.slice(2);

  if (args.length === 0 || args[0] === '--help' || args[0] === '-h') {
    process.stdout.write(HELP);
    process.exit(0);
  }

  if (args[0] === '--version' || args[0] === '-v') {
    process.stdout.write(VERSION + '\n');
    process.exit(0);
  }

  const { provider, remaining } = parseGlobals(args);

  // Re-check --help / --version after stripping globals
  if (remaining.length === 0 || remaining[0] === '--help' || remaining[0] === '-h') {
    process.stdout.write(HELP);
    process.exit(0);
  }
  if (remaining[0] === '--version' || remaining[0] === '-v') {
    process.stdout.write(VERSION + '\n');
    process.exit(0);
  }

  const subcommand = remaining[0]! as Subcommand;
  const subArgs = remaining.slice(1);

  if (!(SUBCOMMANDS as readonly string[]).includes(subcommand)) {
    process.stderr.write(`astramem: unknown subcommand '${subcommand}'.\n\n`);
    process.stdout.write(HELP);
    process.exit(1);
  }

  // Resolve --provider auto → undefined (selector handles auto-probe internally)
  const providerFlag = provider === 'auto' ? undefined : (provider ?? undefined) as 'local' | 'saas' | undefined;

  let exitCode = 0;

  switch (subcommand) {
    case 'ingest-transcript': {
      const { runIngestTranscript } = await import('../src/cli/ingest-transcript.ts');
      exitCode = await runIngestTranscript(subArgs, { provider: providerFlag });
      break;
    }
    case 'recall': {
      const { runRecall } = await import('../src/cli/recall.ts');
      exitCode = await runRecall(subArgs, { provider: providerFlag });
      break;
    }
    case 'remember': {
      const { runRemember } = await import('../src/cli/remember.ts');
      exitCode = await runRemember(subArgs, { provider: providerFlag });
      break;
    }
    case 'health': {
      const { runHealth } = await import('../src/cli/health.ts');
      exitCode = await runHealth(subArgs, { provider: providerFlag });
      break;
    }
    case 'config': {
      const { runConfig } = await import('../src/cli/config-cmd.ts');
      exitCode = await runConfig(subArgs);
      break;
    }
    case 'doctor': {
      const { runDoctor } = await import('../src/cli/doctor.ts');
      exitCode = await runDoctor(subArgs);
      break;
    }
    case 'connect': {
      const { runConnect } = await import('../src/cli/connect.ts');
      exitCode = await runConnect();
      break;
    }
  }

  process.exit(exitCode);
}

main().catch((e: unknown) => {
  process.stderr.write(`astramem: unexpected error: ${(e as Error).message || e}\n`);
  process.exit(1);
});
